class Solution:
    def findMinimumOperations(self, s1, s2, s3):
        lcp = 0
        n = min(len(s1), len(s2), len(s3))
        while lcp < n and s1[lcp] == s2[lcp] == s3[lcp]:
            lcp += 1
        if lcp == 0:
            return -1
        return (len(s1) - lcp) + (len(s2) - lcp) + (len(s3) - lcp)
